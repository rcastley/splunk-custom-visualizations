{
  "label": "Arcade Leaderboard",
  "defaultSize": { "width": 700, "height": 500 },
  "noDataMessage": "INSERT COIN",
  "fields": [
    { "name": "_numPlayers", "label": "Players", "type": "slider", "min": 1, "max": 20, "step": 1, "default": 10 }
  ],
  "formatter": [
    { "name": "title", "label": "Title", "type": "text", "default": "HIGH SCORES" },
    { "name": "maxRows", "label": "Max Rows", "type": "select", "options": ["3", "5", "10", "15", "20"], "default": "10" },
    { "name": "scoreDigits", "label": "Score Digits", "type": "select", "options": [{"v": "0", "l": "No padding"}, {"v": "6", "l": "6 digits"}, {"v": "8", "l": "8 digits"}, {"v": "10", "l": "10 digits"}], "default": "8" },
    { "name": "titleColor", "label": "Title Color", "type": "color", "default": "#00fff5" },
    { "name": "showScanlines", "label": "Scanlines", "type": "radio", "options": ["true", "false"], "default": "true" },
    { "name": "showGlow", "label": "Neon Glow", "type": "radio", "options": ["true", "false"], "default": "true" },
    { "name": "rankFieldName", "label": "Rank Field", "type": "text", "default": "rank" },
    { "name": "nameFieldName", "label": "Name Field", "type": "text", "default": "player_name" },
    { "name": "scoreFieldName", "label": "Score Field", "type": "text", "default": "score" }
  ],
  "data": {
    "mode": "multi_row",
    "columns": ["rank", "player_name", "score"],
