{
  "label": "Scheduler Health",
  "defaultSize": { "width": 600, "height": 300 },
  "noDataMessage": "Awaiting scheduler data",
  "dependencies": [],
  "fields": [
    { "name": "skip_pct", "label": "Skip %", "type": "slider", "min": 0, "max": 100, "step": 0.1, "default": 4.8 },
    { "name": "success_pct", "label": "Success %", "type": "slider", "min": 0, "max": 100, "step": 0.1, "default": 95.2 },
    { "name": "avg_runtime", "label": "Avg Runtime (s)", "type": "slider", "min": 0, "max": 120, "step": 0.5, "default": 12.5 },
    { "name": "total", "label": "Total Searches", "type": "slider", "min": 0, "max": 5000, "step": 1, "default": 1234 },
    { "name": "skipped", "label": "Skipped", "type": "slider", "min": 0, "max": 500, "step": 1, "default": 59 }
  ],
  "formatter": [
    { "name": "colorTheme", "label": "Colour Theme", "type": "select", "options": ["default", "dark", "neon"], "default": "default" },
    { "name": "showGlow", "label": "Show Glow", "type": "radio", "options": ["true", "false"], "default": "true" },
    { "name": "animSpeed", "label": "Animation Speed", "type": "radio", "options": ["slow", "medium", "fast"], "default": "medium" },
    { "name": "runtimeThreshold", "label": "Runtime Threshold", "type": "text", "default": "30" }
  ],
  "data": {
    "mode": "single_row",
    "columns": ["skip_pct", "success_pct", "avg_runtime", "total", "skipped"]
  }
}
